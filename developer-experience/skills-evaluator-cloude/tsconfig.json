{
    "include": ["sandbox/**/*"],
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "atomico",
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "allowJs": true,
        "strict": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"]
    }
}
